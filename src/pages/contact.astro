---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us | Timber">

  <!-- Header -->
  <section class="bg-[#2f6b35] text-white py-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-[#a8d4ab] uppercase tracking-[0.3em] text-sm font-semibold mb-3">Get In Touch</p>
      <h1 class="text-6xl md:text-7xl font-black uppercase leading-none" style="font-family: 'Oswald', sans-serif;">
        Contact Us
      </h1>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="bg-[#f5edd8] py-16">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12">

      <!-- Form -->
      <div class="bg-white rounded-lg shadow-sm p-8">
        <h2 class="text-2xl font-bold uppercase tracking-wide mb-6" style="font-family: 'Oswald', sans-serif;">Send Us a Message</h2>

        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
          <input type="hidden" name="access_key" value="ccb4b8a1-9b01-4e31-b639-4a1621071abf" />
          <input type="hidden" name="subject" value="New contact form submission - Timber" />
          <input type="hidden" name="redirect" value="https://www.timberreserve.com/contact?success=true" />
          <input type="checkbox" name="botcheck" class="hidden" />

          <div>
            <label for="name" class="block text-sm font-semibold uppercase tracking-wide text-gray-700 mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Your full name"
              class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 focus:outline-none focus:border-[#2f6b35] focus:ring-1 focus:ring-[#2f6b35]"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold uppercase tracking-wide text-gray-700 mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 focus:outline-none focus:border-[#2f6b35] focus:ring-1 focus:ring-[#2f6b35]"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-semibold uppercase tracking-wide text-gray-700 mb-1">Phone <span class="text-gray-400 normal-case font-normal">(optional)</span></label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="864.000.0000"
              class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 focus:outline-none focus:border-[#2f6b35] focus:ring-1 focus:ring-[#2f6b35]"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold uppercase tracking-wide text-gray-700 mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Tell us about your project..."
              class="w-full border border-gray-300 rounded px-4 py-3 text-gray-900 focus:outline-none focus:border-[#2f6b35] focus:ring-1 focus:ring-[#2f6b35] resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-[#2f6b35] text-[#f5edd8] py-4 font-bold uppercase tracking-wider hover:bg-[#245228] transition-colors rounded text-lg"
          >
            Send Message
          </button>
        </form>

        <!-- Success message -->
        <div id="success-msg" class="hidden mt-6 bg-[#e8f5e9] border border-[#2f6b35] text-[#2f6b35] rounded px-5 py-4 font-semibold">
          Thanks! We'll be in touch soon.
        </div>
      </div>

      <!-- Contact info -->
      <div class="flex flex-col gap-8">
        <div>
          <h2 class="text-2xl font-bold uppercase tracking-wide mb-6" style="font-family: 'Oswald', sans-serif;">Reach Us Directly</h2>
          <ul class="space-y-5">
            <li class="flex items-start gap-4">
              <span class="text-2xl mt-0.5">📞</span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-0.5">Phone</p>
                <a href="tel:8643265491" class="text-xl font-bold text-[#2f6b35] hover:text-[#245228] transition-colors">864.326.5491</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="text-2xl mt-0.5">✉️</span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-0.5">Email</p>
                <a href="mailto:yallfixit@gmail.com" class="text-xl font-bold text-[#2f6b35] hover:text-[#245228] transition-colors">yallfixit@gmail.com</a>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="text-2xl mt-0.5">📍</span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-gray-500 mb-0.5">Service Areas</p>
                <p class="text-lg font-semibold text-gray-800 leading-relaxed">Greenville, SC<br/>Clayton, GA<br/>Knoxville, TN</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="bg-[#2f6b35] text-white rounded-lg p-6">
          <p class="text-2xl font-black uppercase leading-tight mb-2" style="font-family: 'Oswald', sans-serif;">Done Right.<br/>Done Fast.<br/>Work Guaranteed.</p>
          <p class="text-[#a8d4ab] text-sm">Free estimates on all projects. We'll get back to you within one business day.</p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  // Show inline success message if redirected back with ?success=true
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === 'true') {
    document.getElementById('success-msg')?.classList.remove('hidden');
    window.history.replaceState({}, '', '/contact');
  }
</script>
