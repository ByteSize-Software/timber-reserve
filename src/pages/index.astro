---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home | Timber Reserve">
  <section class="text-center py-20">
    <h1 class="text-5xl font-bold text-gray-900 mb-4">Welcome to Timber Reserve</h1>
    <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
      A blazing-fast website built with Astro and styled with Tailwind CSS.
    </p>
    <a
      href="https://docs.astro.build"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block bg-indigo-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-indigo-700 transition-colors"
    >
      Read the Docs
    </a>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10">
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow">
      <h2 class="text-xl font-semibold mb-2">Fast by Default</h2>
      <p class="text-gray-600">Astro ships zero JavaScript by default, making your site lightning fast.</p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow">
      <h2 class="text-xl font-semibold mb-2">Tailwind Styled</h2>
      <p class="text-gray-600">Utility-first CSS with Tailwind gives you full design flexibility.</p>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow">
      <h2 class="text-xl font-semibold mb-2">Ready to Build</h2>
      <p class="text-gray-600">Your project is scaffolded and ready. Start building something great!</p>
    </div>
  </section>
</BaseLayout>
