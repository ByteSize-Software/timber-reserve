---
import BaseLayout from '../layouts/BaseLayout.astro';
import heroImg1 from '../assets/images/rental.jpg';
import heroImg2 from '../assets/images/remodel.jpg';
import remodelImg from '../assets/images/remodel.jpg';
import bathroomImg from '../assets/images/bathroom.jpg';
import fireplaceStoneImg from '../assets/images/fireplace-with-stone.jpg';
import deckImg from '../assets/images/deck.jpg';
import showerImg from '../assets/images/shower.jpg';
import bunkbedsImg from '../assets/images/custom-bunkbeds.jpg';
import roofingImg from '../assets/images/roofing.jpg';
import outdoorStairsImg from '../assets/images/outdoor-stairs.jpg';

const services = [
  { icon: '🏚️', title: 'Porch & Deck Repair',        slug: 'porch-and-deck-repair',      desc: 'Sagging boards, rotted posts, loose railings — we fix the porch and deck problems most contractors won\'t touch.' },
  { icon: '🔧', title: 'Roof Repair & Leak Patching', slug: 'roof-repair',                 desc: 'Patches, flashing fixes, and leak repairs. We stop the damage before it spreads, without selling you a full replacement.' },
  { icon: '🪟', title: 'Drywall & Sheetrock Repair',  slug: 'drywall-repair',              desc: 'Holes, water damage, doorknob dents — patched and finished so you can\'t tell it was ever there.' },
  { icon: '🪵', title: 'Flooring',                    slug: 'flooring',                    desc: 'Carpet removal, hardwood refinishing, and damaged floor repair. We get floors looking new again.' },
  { icon: '🪚', title: 'Custom Woodwork',             slug: 'custom-woodwork',             desc: 'Mantles, built-ins, and one-of-a-kind pieces using real wood and sawmill lumber. Built for homes with character.' },
  { icon: '🏡', title: 'Pre-Listing Repairs',         slug: 'pre-listing-repairs',         desc: 'House sitting on the market? We fix what\'s keeping buyers away so your listing can close at full value.' },
  { icon: '🔑', title: 'Property Management Turnover', slug: 'property-management-turnover', desc: 'Fast, reliable between-tenant repairs. Sheetrock, paint, floors, fixtures — we get your rental rent-ready.' },
];

const gallery = [
  { src: remodelImg.src,        label: 'Full Remodel',       featured: true },
  { src: bathroomImg.src,       label: 'Bathroom Work',      featured: false },
  { src: fireplaceStoneImg.src, label: 'Custom Stonework',   featured: false },
  { src: deckImg.src,           label: 'Deck Repair',        featured: false },
  { src: showerImg.src,         label: 'Tile & Shower',      featured: false },
  { src: bunkbedsImg.src,       label: 'Custom Woodwork',    featured: false },
  { src: roofingImg.src,        label: 'Roof Repair',        featured: false },
  { src: outdoorStairsImg.src,  label: 'Outdoor Stairs',     featured: false },
];
---

<BaseLayout title="Timber Reserve | Home Repairs, Renovations & Small Builds">

  <!-- Hero -->
  <section id="hero-section" class="bg-[#2f6b35] text-white relative overflow-hidden md:min-h-[calc(100vh-72px)] flex items-center">

    <!-- Mobile background photo (full bleed, single image) -->
    <div class="absolute inset-0 md:hidden">
      <img src={heroImg1.src} alt="" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-[#2f6b35]/85"></div>
    </div>

    <!-- Desktop background photos: two stacked images visible on the right -->
    <div class="absolute inset-y-0 right-0 w-[55%] hidden md:grid grid-rows-2">
      <img src={heroImg1.src} alt="" class="w-full h-full object-cover object-center" />
      <img src={heroImg2.src} alt="" class="w-full h-full object-cover object-center" />
    </div>

    <!-- Desktop gradient overlay: solid green on left, fades to reveal photos on right -->
    <div class="absolute inset-0 hidden md:block"
      style="background: linear-gradient(to right, #2f6b35 28%, rgba(47,107,53,0.97) 38%, rgba(47,107,53,0.65) 55%, rgba(47,107,53,0.15) 75%, rgba(0,0,0,0.25) 100%);">
    </div>

    <!-- Subtle pattern texture -->
    <div class="absolute inset-0 opacity-10"
      style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 20px 20px;">
    </div>

    <div id="hero-inner" class="relative max-w-6xl mx-auto px-6 py-8 md:py-12 w-full grid md:grid-cols-2 gap-8 md:gap-12 items-center">

      <!-- Left: Headline -->
      <div>
        <p class="text-[#a8d4ab] uppercase tracking-[0.3em] text-sm font-semibold mb-4">Fieldworks &bull; Home &bull; Trades</p>
        <h1 class="text-7xl sm:text-8xl md:text-8xl lg:text-[11rem] font-black uppercase leading-none tracking-tight mb-6 overflow-hidden" style="font-family: 'Oswald', sans-serif;">
          <span id="word-we"    class="word-hidden">We</span>
          <span id="word-build" class="word-hidden">Build</span>
          <span id="word-stuff" class="word-hidden text-[#f5edd8]">Stuff.</span>
        </h1>
        <p class="text-lg text-[#c8e6ca] leading-relaxed">
          Repairs, renovations, and small builds in Greenville SC, Knoxville TN, and Clayton GA. The jobs other contractors won't take — done right.
        </p>
      </div>

      <!-- Right: CTA -->
      <div class="flex flex-col gap-4 md:items-start">
        <a href="tel:8643265491"
          class="w-full md:w-auto bg-[#4a3219] text-[#f5edd8] px-10 py-5 text-xl font-bold uppercase tracking-wider hover:bg-[#3a2510] transition-colors rounded text-center">
          Call Now
        </a>
        <a href="/services"
          class="hidden md:block w-full md:w-auto border-2 border-[#f5edd8] text-[#f5edd8] px-10 py-5 text-xl font-bold uppercase tracking-wider hover:bg-[#f5edd8] hover:text-[#2f6b35] transition-colors rounded text-center">
          Our Services
        </a>
      </div>

    </div>
  </section>

  <!-- Tagline Banner -->
  <section class="bg-[#4a3219] text-[#f5edd8] py-6">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-lg sm:text-2xl md:text-3xl font-bold tracking-wide whitespace-nowrap" style="font-family: 'Oswald', sans-serif;">
        Done Right. &nbsp; Done Fast. &nbsp; Work Guaranteed.
      </p>
    </div>
  </section>

  <!-- Who We Serve -->
  <section class="bg-[#f5edd8] py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <p class="text-[#2f6b35] uppercase tracking-[0.3em] text-sm font-semibold mb-2">Who We Work For</p>
        <h2 class="text-5xl font-black uppercase" style="font-family: 'Oswald', sans-serif;">We Serve You</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">

        <div class="bg-white rounded-lg shadow-sm overflow-hidden">
          <div class="bg-[#2f6b35] px-6 py-4">
            <h3 class="text-2xl font-black uppercase text-white" style="font-family: 'Oswald', sans-serif;">Homeowners</h3>
          </div>
          <div class="p-6">
            <p class="text-gray-600 leading-relaxed mb-4">Small jobs that are hard to find help with — that's our specialty. If you need a porch repaired, a leak patched, a shed built, or a shower redone, we show up and we finish the job.</p>
            <ul class="space-y-1 text-sm text-gray-700">
              <li class="flex gap-2"><span class="text-[#2f6b35]">✓</span> Porch & deck repair</li>
              <li class="flex gap-2"><span class="text-[#2f6b35]">✓</span> Roof patches & leak fixes</li>
              <li class="flex gap-2"><span class="text-[#2f6b35]">✓</span> Shed & outbuilding builds</li>
              <li class="flex gap-2"><span class="text-[#2f6b35]">✓</span> Bathroom & shower work</li>
            </ul>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm overflow-hidden">
          <div class="bg-[#4a3219] px-6 py-4">
            <h3 class="text-2xl font-black uppercase text-[#f5edd8]" style="font-family: 'Oswald', sans-serif;">Property Managers</h3>
          </div>
          <div class="p-6">
            <p class="text-gray-600 leading-relaxed mb-4">We flip rental homes between tenants fast. Hole in the sheetrock, damaged flooring, stains on the ceiling — we come in, fix it all, and get your property rent-ready on schedule.</p>
            <ul class="space-y-1 text-sm text-gray-700">
              <li class="flex gap-2"><span class="text-[#4a3219]">✓</span> Full turnover repairs</li>
              <li class="flex gap-2"><span class="text-[#4a3219]">✓</span> Drywall & sheetrock</li>
              <li class="flex gap-2"><span class="text-[#4a3219]">✓</span> Flooring replacement</li>
              <li class="flex gap-2"><span class="text-[#4a3219]">✓</span> Ceiling & water stain repair</li>
            </ul>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm overflow-hidden">
          <div class="bg-[#2f6b35] px-6 py-4">
            <h3 class="text-2xl font-black uppercase text-white" style="font-family: 'Oswald', sans-serif;">Realtors</h3>
          </div>
          <div class="p-6">
            <p class="text-gray-600 leading-relaxed mb-4">If a listing has been sitting on the market for 45 days, we know why. We come in, fix what's drawing attention, and get the house to the condition buyers want — at or above market value.</p>
            <ul class="space-y-1 text-sm text-gray-700">
              <li class="flex gap-2"><span class="text-[#2f6b35]">✓</span> Pre-listing punch list repairs</li>
              <li class="flex gap-2"><span class="text-[#2f6b35]">✓</span> Floor refinishing</li>
              <li class="flex gap-2"><span class="text-[#2f6b35]">✓</span> Ceiling stain repair</li>
              <li class="flex gap-2"><span class="text-[#2f6b35]">✓</span> Roof leak patching</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12 flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-[#2f6b35] uppercase tracking-[0.3em] text-sm font-semibold mb-2">What We Do</p>
          <h2 class="text-5xl font-black uppercase" style="font-family: 'Oswald', sans-serif;">Our Services</h2>
        </div>
        <a href="/services" class="text-[#2f6b35] font-semibold uppercase tracking-wide text-sm hover:underline">View All →</a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/services/${s.slug}`} class="bg-[#f5edd8] border-l-4 border-[#2f6b35] p-6 shadow-sm hover:shadow-md transition-shadow rounded-r group">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-[#2f6b35] transition-colors" style="font-family: 'Oswald', sans-serif;">{s.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{s.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Work Gallery -->
  <section class="bg-[#1e4a22] py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12">
        <p class="text-[#a8d4ab] uppercase tracking-[0.3em] text-sm font-semibold mb-2">Portfolio</p>
        <h2 class="text-5xl font-black uppercase text-white" style="font-family: 'Oswald', sans-serif;">Our Work</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {gallery.map((item) => (
          <div class={`relative overflow-hidden rounded group ${item.featured ? 'col-span-2 md:col-span-2' : 'col-span-1'}`}>
            <img
              src={item.src}
              alt={item.label}
              class="w-full h-52 md:h-72 object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent flex items-end p-4">
              <span class="text-white font-bold uppercase tracking-wide text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="font-family: 'Oswald', sans-serif;">{item.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About / CTA -->
  <section class="bg-[#2f6b35] text-white py-20">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-[#a8d4ab] uppercase tracking-[0.3em] text-sm font-semibold mb-3">Why Timber Reserve</p>
        <h2 class="text-5xl font-black uppercase leading-tight mb-6" style="font-family: 'Oswald', sans-serif;">
          One Crew.<br/>Every Job.
        </h2>
        <p class="text-[#c8e6ca] text-lg leading-relaxed mb-4">
          We're your one stop shop. That means one call, one crew, one point of accountability. We handle repairs, renovations, dirt work, and small builds — the jobs most contractors won't bother with and the ones that actually matter to you.
        </p>
        <p class="text-[#c8e6ca] text-lg leading-relaxed mb-8">
          Serving homeowners, property managers, and realtors across Greenville SC, Knoxville TN, and Clayton GA.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="tel:8643265491"
            class="bg-[#f5edd8] text-[#2f6b35] px-8 py-4 font-bold uppercase tracking-wider hover:bg-white transition-colors rounded text-center">
            864.326.5491
          </a>
          <a href="/contact"
            class="border-2 border-[#f5edd8] text-[#f5edd8] px-8 py-4 font-bold uppercase tracking-wider hover:bg-[#f5edd8] hover:text-[#2f6b35] transition-colors rounded text-center">
            Get a Free Estimate
          </a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        {[
          'Licensed & Insured',
          'Free Estimates',
          'Satisfaction Guaranteed',
          'Locally Owned',
          'Serving 3 States',
          'All Trades In-House',
        ].map((item) => (
          <div class="bg-[#245228] rounded p-4 flex items-center gap-3">
            <span class="text-[#a8d4ab] text-xl">✓</span>
            <span class="font-semibold text-sm uppercase tracking-wide">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="bg-[#f5edd8] py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-10">
        <p class="text-[#2f6b35] uppercase tracking-[0.3em] text-sm font-semibold mb-2">Where We Work</p>
        <h2 class="text-5xl font-black uppercase" style="font-family: 'Oswald', sans-serif;">Service Areas</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <a href="/locations/greenville-sc" class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow group">
          <h3 class="text-2xl font-black uppercase mb-2 group-hover:text-[#2f6b35] transition-colors" style="font-family: 'Oswald', sans-serif;">Greenville, SC</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Rental property management, realtor pre-listing repairs, and residential homeowner work throughout the Greenville metro.</p>
        </a>

        <a href="/locations/knoxville-tn" class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow group">
          <h3 class="text-2xl font-black uppercase mb-2 group-hover:text-[#2f6b35] transition-colors" style="font-family: 'Oswald', sans-serif;">Knoxville, TN</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Property management turnovers, realtor repairs, and homeowner projects in Knoxville and surrounding communities including Madisonville and Tellico.</p>
        </a>

        <a href="/locations/clayton-ga" class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow group">
          <h3 class="text-2xl font-black uppercase mb-2 group-hover:text-[#2f6b35] transition-colors" style="font-family: 'Oswald', sans-serif;">Clayton, GA</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Mountain homes, lakeside cabins, and retirement properties in Clayton and the North Georgia mountains. Custom woodwork our specialty here.</p>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const hero = document.getElementById('hero-inner') as HTMLElement;

  const sequence: Array<{ id: string; delay: number; shake: string }> = [
    { id: 'word-we',    delay: 300,  shake: 'shake-sm' },
    { id: 'word-build', delay: 750,  shake: 'shake-md' },
    { id: 'word-stuff', delay: 1250, shake: 'shake-lg' },
  ];

  sequence.forEach(({ id, delay, shake }) => {
    setTimeout(() => {
      const word = document.getElementById(id)!;
      word.classList.add('word-slam');

      setTimeout(() => {
        hero.classList.remove('shake-sm', 'shake-md', 'shake-lg');
        void hero.offsetWidth;
        hero.classList.add(shake);
      }, 120);
    }, delay);
  });
</script>
