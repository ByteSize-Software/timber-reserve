---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    slug: 'porch-and-deck-repair',
    icon: '🏚️',
    title: 'Porch & Deck Repair',
    desc: 'Sagging boards, rotted posts, loose railings. We fix the porch and deck problems most contractors won\'t touch.',
  },
  {
    slug: 'roof-repair',
    icon: '🔧',
    title: 'Roof Repair & Leak Patching',
    desc: 'Patches, flashing fixes, and leak repairs before the damage spreads — without selling you a full replacement.',
  },
  {
    slug: 'drywall-repair',
    icon: '🪟',
    title: 'Drywall & Sheetrock Repair',
    desc: 'Holes, water damage, and doorknob dents patched and finished so you can\'t tell it was ever there.',
  },
  {
    slug: 'flooring',
    icon: '🪵',
    title: 'Flooring',
    desc: 'Carpet removal, hardwood refinishing, and damaged floor replacement. We get floors looking new again.',
  },
  {
    slug: 'custom-woodwork',
    icon: '🪚',
    title: 'Custom Woodwork & Interiors',
    desc: 'Mantles, built-ins, and one-of-a-kind pieces using real wood and sawmill lumber. Built for homes with character.',
  },
  {
    slug: 'pre-listing-repairs',
    icon: '🏡',
    title: 'Pre-Listing Home Repairs',
    desc: 'House sitting on the market? We fix what\'s keeping buyers away so your listing can close at full value.',
  },
  {
    slug: 'property-management-turnover',
    icon: '🔑',
    title: 'Property Management Turnover',
    desc: 'Fast, reliable between-tenant repairs. Sheetrock, paint, floors, fixtures — we get your rental rent-ready.',
  },
];
---

<BaseLayout title="Services | Timber Reserve">

  <section class="bg-[#2f6b35] text-white py-16">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-[#a8d4ab] uppercase tracking-[0.3em] text-sm font-semibold mb-3">What We Do</p>
      <h1 class="text-6xl md:text-7xl font-black uppercase leading-none mb-4" style="font-family: 'Oswald', sans-serif;">Our Services</h1>
      <p class="text-[#c8e6ca] text-lg max-w-2xl">
        We build stuff, fix stuff, and handle the small jobs that most people who aren't professionals find difficult to get help with. One crew. Every trade. Done right.
      </p>
    </div>
  </section>

  <section class="bg-[#f5edd8] py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/services/${s.slug}`} class="bg-white border-l-4 border-[#2f6b35] p-6 shadow-sm hover:shadow-md transition-shadow rounded-r group">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h2 class="text-xl font-bold uppercase tracking-wide mb-2 group-hover:text-[#2f6b35] transition-colors" style="font-family: 'Oswald', sans-serif;">{s.title}</h2>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{s.desc}</p>
            <span class="text-[#2f6b35] text-sm font-semibold uppercase tracking-wide">Learn More →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#2f6b35] text-white py-12">
    <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-2xl font-black uppercase" style="font-family: 'Oswald', sans-serif;">Ready to get started?</p>
        <p class="text-[#c8e6ca]">Free estimates on every job. We'll get back to you within one business day.</p>
      </div>
      <div class="flex gap-4 flex-shrink-0">
        <a href="tel:8643265491" class="bg-[#4a3219] text-[#f5edd8] px-8 py-4 font-bold uppercase tracking-wider hover:bg-[#3a2510] transition-colors rounded">
          864.326.5491
        </a>
        <a href="/contact" class="border-2 border-[#f5edd8] text-[#f5edd8] px-8 py-4 font-bold uppercase tracking-wider hover:bg-[#f5edd8] hover:text-[#2f6b35] transition-colors rounded">
          Free Estimate
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
