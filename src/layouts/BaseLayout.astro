---
const { title = 'Timber Reserve' } = Astro.props;
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Timber Reserve" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <header class="bg-gray-800 text-white py-4 px-6 shadow-md">
      <nav class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="text-xl font-bold hover:text-gray-300 transition-colors">Timber Reserve</a>
        <ul class="flex gap-6">
          <li><a href="/" class="hover:text-gray-300 transition-colors">Home</a></li>
        </ul>
      </nav>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-10">
      <slot />
    </main>

    <footer class="bg-gray-800 text-white text-center py-4 mt-10">
      <p class="text-sm text-gray-400">&copy; {new Date().getFullYear()} Timber Reserve. All rights reserved.</p>
    </footer>
  </body>
</html>
